{
  "info": {
    "_postman_id": "dd940805-7c80-4cc9-b95e-bf4bda14f311",
    "name": "Lab14 - Lab11 Tic Tac Toe API",
    "description": "F.CSM311 Lab14 collection for the Lab11 Tic Tac Toe API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Game",
      "item": [
        {
          "name": "Happy GET - health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Checks that the Lab11 Tic Tac Toe API server is running."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response under 1000ms', () => pm.expect(pm.response.responseTime).to.be.below(1000));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Service status is ok', () => pm.expect(body.status).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST create game",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('gameName', `Lab11 game ${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const game = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Created game has id', () => pm.expect(game.id).to.be.a('string').and.not.empty);",
                  "pm.test('Created game starts with X', () => pm.expect(game.currentPlayer).to.eql('X'));",
                  "pm.test('Board has 9 cells', () => pm.expect(game.cells).to.be.an('array').with.lengthOf(9));",
                  "pm.test('Created name matches generated name', () => pm.expect(game.name).to.eql(pm.environment.get('gameName')));",
                  "pm.environment.set('gameId', game.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{gameName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/games",
              "host": ["{{baseUrl}}"],
              "path": ["games"]
            },
            "description": "Creates a new Tic Tac Toe game and stores its id for chained requests."
          }
        },
        {
          "name": "GET by chained game id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/games/{{gameId}}",
              "host": ["{{baseUrl}}"],
              "path": ["games", "{{gameId}}"]
            },
            "description": "Reads the game created by the previous request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const game = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Chained id matches response id', () => pm.expect(game.id).to.eql(pm.environment.get('gameId')));",
                  "pm.test('Game schema is valid', () => pm.expect(game).to.include.keys(['id', 'name', 'cells', 'currentPlayer', 'status', 'canUndo']));",
                  "pm.test('Initial game is in progress', () => pm.expect(game.status).to.eql('in_progress'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST play move",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"x\": 0,\n  \"y\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/games/{{gameId}}/moves",
              "host": ["{{baseUrl}}"],
              "path": ["games", "{{gameId}}", "moves"]
            },
            "description": "Plays X at the top-left cell."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const game = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('First cell is X', () => pm.expect(game.cells[0]).to.eql('X'));",
                  "pm.test('Next player is O', () => pm.expect(game.currentPlayer).to.eql('O'));",
                  "pm.test('Undo is available after a move', () => pm.expect(game.canUndo).to.eql(true));"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT reset game",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/games/{{gameId}}/reset",
              "host": ["{{baseUrl}}"],
              "path": ["games", "{{gameId}}", "reset"]
            },
            "description": "Resets the chained game to an empty board."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const game = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Board is empty after reset', () => pm.expect(game.cells.every(cell => cell === '')).to.eql(true));",
                  "pm.test('Reset game current player is X', () => pm.expect(game.currentPlayer).to.eql('X'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Error case - invalid move payload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"x\": 9,\n  \"y\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/games/{{gameId}}/moves",
              "host": ["{{baseUrl}}"],
              "path": ["games", "{{gameId}}", "moves"]
            },
            "description": "Negative validation path for an invalid move coordinate."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const error = pm.response.json();",
                  "pm.test('Status 400 for invalid payload', () => pm.response.to.have.status(400));",
                  "pm.test('Validation error body has message', () => pm.expect(error.error).to.be.a('string').and.not.empty);",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE game",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/games/{{gameId}}",
              "host": ["{{baseUrl}}"],
              "path": ["games", "{{gameId}}"]
            },
            "description": "Deletes the game created during this run."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));",
                  "pm.test('Delete response body is empty', () => pm.expect(pm.response.text()).to.eql(''));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Errors",
      "item": [
        {
          "name": "Error case - missing game",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"x\": 9,\n  \"y\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/games/missing-game/moves",
              "host": ["{{baseUrl}}"],
              "path": ["games", "missing-game", "moves"]
            },
            "description": "Negative path for a move request against a missing game."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const error = pm.response.json();",
                  "pm.test('Status 404 for missing game', () => pm.response.to.have.status(404));",
                  "pm.test('Error body has message', () => pm.expect(error.error).to.be.a('string').and.not.empty);",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Error case - route not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/not-found",
              "host": ["{{baseUrl}}"],
              "path": ["not-found"]
            },
            "description": "Checks the API returns 404 for unknown routes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const error = pm.response.json();",
                  "pm.test('Status 404 for unknown route', () => pm.response.to.have.status(404));",
                  "pm.test('Route error is explicit', () => pm.expect(error.error).to.eql('Route not found'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
