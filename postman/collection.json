{
  "info": {
    "_postman_id": "dd940805-7c80-4cc9-b95e-bf4bda14f311",
    "name": "Lab14 - JSONPlaceholder API",
    "description": "F.CSM311 Lab14 API testing collection for JSONPlaceholder fake REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "Happy GET - list posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Returns a list of posts and stores the first id for chained requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response under 1500ms', () => pm.expect(pm.response.responseTime).to.be.below(1500));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "const posts = pm.response.json();",
                  "pm.test('Body is non-empty array', () => {",
                  "  pm.expect(posts).to.be.an('array').that.is.not.empty;",
                  "});",
                  "pm.test('First post has numeric id and title', () => {",
                  "  pm.expect(posts[0]).to.have.property('id');",
                  "  pm.expect(posts[0].id).to.be.a('number');",
                  "  pm.expect(posts[0].title).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.environment.set('firstPostId', posts[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET by chained id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{firstPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{firstPostId}}"]
            },
            "description": "Uses the firstPostId variable captured from the list response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const post = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Chained id matches response id', () => pm.expect(String(post.id)).to.eql(String(pm.environment.get('firstPostId'))));",
                  "pm.test('Post schema has userId id title body', () => {",
                  "  pm.expect(post).to.include.keys(['userId', 'id', 'title', 'body']);",
                  "  pm.expect(post.userId).to.be.a('number');",
                  "  pm.expect(post.body).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET by id - post 1",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Returns one existing post by a fixed id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const post = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Id is exactly 1', () => pm.expect(post.id).to.eql(1));",
                  "pm.test('Title is a string', () => pm.expect(post.title).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST create post",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.environment.set('randomTitle', `lab14 post ${suffix}`);",
                  "pm.environment.set('randomBody', `generated body ${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const created = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Created post has id', () => {",
                  "  pm.expect(created).to.have.property('id');",
                  "  pm.expect(created.id).to.be.a('number');",
                  "});",
                  "pm.test('Created title matches generated title', () => pm.expect(created.title).to.eql(pm.environment.get('randomTitle')));",
                  "pm.test('Created userId is valid business value', () => pm.expect(created.userId).to.be.within(1, 10));",
                  "pm.environment.set('postId', created.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{randomTitle}}\",\n  \"body\": \"{{randomBody}}\",\n  \"userId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Creates a fake post with random data generated in a pre-request script."
          }
        },
        {
          "name": "PUT update post",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"title\": \"updated lab14 title\",\n  \"body\": \"updated lab14 body\",\n  \"userId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Replaces an existing fake post and checks that the update is echoed back."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const updated = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Updated title persisted in response', () => pm.expect(updated.title).to.eql('updated lab14 title'));",
                  "pm.test('Updated id and userId are numbers', () => {",
                  "  pm.expect(updated.id).to.be.a('number');",
                  "  pm.expect(updated.userId).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH update title",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"patched lab14 title\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Partially updates the post title."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const patched = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Patched title returned', () => pm.expect(patched.title).to.eql('patched lab14 title'));"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "1"]
            },
            "description": "Deletes a fake post and accepts JSONPlaceholder's successful empty response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Delete response is empty object', () => pm.expect(pm.response.json()).to.deep.eql({}));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Errors",
      "item": [
        {
          "name": "Error case - missing post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/999999",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "999999"]
            },
            "description": "Negative test for a post id that does not exist."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404 for missing resource', () => pm.response.to.have.status(404));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Error body is an empty object', () => pm.expect(pm.response.json()).to.deep.eql({}));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
